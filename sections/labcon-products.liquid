          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/glassware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M8 2h8l1 6H7L8 2z"/><path d="M7 8c0 6 3 12 5 12s5-6 5-12"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Glassware</h4>
          <p class="labcon-cat-card__desc">Lab Glass Tools</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/volumetricware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2h12v4l2 14H4L6 6V2z"/><path d="M6 10h12"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Volumetricware</h4>
          <p class="labcon-cat-card__desc">Volumetric Tools</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/sampleware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2a5 5 0 015 5v3H7V7a5 5 0 015-5z"/><rect x="5" y="10" width="14" height="12" rx="2"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Sampleware</h4>
          <p class="labcon-cat-card__desc">Sample Collection</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/cultureware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15 15 0 010 20"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Cultureware</h4>
          <p class="labcon-cat-card__desc">Microbiology Culture</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/safetyware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Safetyware</h4>
          <p class="labcon-cat-card__desc">Lab Safety Supplies</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/generalware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Generalware</h4>
          <p class="labcon-cat-card__desc">General Consumables</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
.labcon-products__header {
  margin-bottom: 48px;
}

.labcon-family {
  background: #ffffff;
  border-radius: 4px;
  padding: 36px;
  border: 1px solid #ebebeb;
}

.labcon-family__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 28px;
  padding-bottom: 20px;
  border-bottom: 2px solid #f0f0f0;
  flex-wrap: wrap;
}

.labcon-family__title {
  font-size: 20px;
  font-weight: 700;
  color: #0e0e0d;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 14px;
}

.labcon-family__num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  background: #e53d1c;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  border-radius: 2px;
  flex-shrink: 0;
}

.labcon-family__desc {
  font-size: 14px;
  color: #6f7070;
  margin: 0;
  max-width: 460px;
  line-height: 1.55;
}

/* Category card grid */
.labcon-cat-grid {
  display: grid;
  gap: 16px;
}
.labcon-cat-grid--4 {
  grid-template-columns: repeat(4, 1fr);
}

/* Category card */
.labcon-cat-card {
  background: #f7f8f7;
  border: 1px solid #ebebeb;
  border-radius: 3px;
  padding: 20px 18px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-decoration: none;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
}
.labcon-cat-card:hover {
  border-color: #e53d1c;
  box-shadow: 0 4px 18px rgba(229,61,28,0.1);
  transform: translateY(-2px);
  text-decoration: none;
}

.labcon-cat-card__icon {
  width: 36px;
  height: 36px;
  margin-bottom: 6px;
  color: #e53d1c;
}
.labcon-cat-card__icon svg {
  width: 100%;
  height: 100%;
}

.labcon-cat-card__name {
  font-size: 18px;
  font-weight: 700;
  color: #0e0e0d;
  margin: 0;
  line-height: 1.3;
}

.labcon-cat-card__desc {
  font-size: 16px;
  color: #6f7070;
  margin: 0;
  line-height: 1.4;
}

.labcon-cat-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 600;
  color: #e53d1c;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: auto;
  padding-top: 10px;
}
.labcon-cat-card__cta svg {
  width: 14px;
  height: 14px;
  transition: transform 0.2s;
}
.labcon-cat-card:hover .labcon-cat-card__cta svg {
  transform: translateX(3px);
}

/* Responsive */
@media (max-width: 1200px) {
  .labcon-cat-grid--4 { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .labcon-family { padding: 24px 16px; }
  .labcon-cat-grid--4 { grid-template-columns: repeat(2, 1fr); }
  .labcon-family__header { flex-direction: column; gap: 8px; }
}
@media (max-width: 480px) {
  .labcon-cat-grid--4 { grid-template-columns: 1fr 1fr; }
}
</style>

{% schema %}
{
  "name": "LABCON Product Families",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Product Portfolio"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Two Product Families. One Trusted Supplier."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "LABCON organizes its catalog into two focused product families to help you find exactly what your laboratory needs."
    }
  ],
  "presets": [{ "name": "LABCON Product Families" }]
}
{% endschema %}
