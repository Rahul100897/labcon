<section class="labcon-products lc-section" style="background: #f7f8f7;">
  <div class="container">

    <!-- Section header -->
    <div class="labcon-products__header">
      <span class="lc-label">{{ section.settings.label | default: 'Product Portfolio' }}</span>
      <h2 class="lc-heading">{{ section.settings.heading | default: 'Two Product Families. One Trusted Supplier.' }}</h2>
      <p class="lc-subtext" style="max-width:560px;">
        {{ section.settings.subtext | default: 'LABCON organizes its catalog into two focused product families to help you find exactly what your laboratory needs.' }}
      </p>
    </div>

    <!-- Family 1: Analytical & Reference Products -->
    <div class="labcon-family">
      <div class="labcon-family__header">
        <h3 class="labcon-family__title">
          <span class="labcon-family__num">01</span>
          Analytical &amp; Reference Products
        </h3>
        <p class="labcon-family__desc">Precision products for chromatography, reference standards, biological materials, and high-purity solvents.</p>
      </div>
      <div class="labcon-cat-grid labcon-cat-grid--4">
        <a href="/collections/referenceware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Referenceware</h4>
          <p class="labcon-cat-card__desc">Reference Materials &amp; Standards</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/analyticalware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 3v11a3 3 0 006 0V3"/><path d="M6 3h12"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Analyticalware</h4>
          <p class="labcon-cat-card__desc">Chromatography Consumables</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/bioware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="3"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Bioware</h4>
          <p class="labcon-cat-card__desc">Biological Products</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
        <a href="/collections/solvents-reagents" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M10 2v7.31l-3.24 4.65A2 2 0 008.4 17H15.6a2 2 0 001.64-3.04L14 9.31V2"/><path d="M8.5 2h7"/></svg>
          </div>
          <h4 class="labcon-cat-card__name">Solvents &amp; Reagents</h4>
          <p class="labcon-cat-card__desc">High-Purity Solvents &amp; Reagents</p>
          <span class="labcon-cat-card__cta">View Products <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg></span>
        </a>
      </div>
    </div>

    <!-- Family 2: Laboratory Consumables -->
    <div class="labcon-family" style="margin-top: 56px;">
      <div class="labcon-family__header">
        <h3 class="labcon-family__title">
          <span class="labcon-family__num">02</span>
          Laboratory Consumables
        </h3>
        <p class="labcon-family__desc">Everyday consumables covering filtration, plasticware, glassware, volumetrics, sampling, microbiology, safety, and general supplies.</p>
      </div>
      <div class="labcon-cat-grid labcon-cat-grid--4">
        <a href="/collections/filterware" class="labcon-cat-card">
          <div class="labcon-cat-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
