<section class="labcon-intro lc-section">
  <div class="container">
    <div class="labcon-intro__grid">

      <!-- Left: text block -->
      <div class="labcon-intro__text">
        <span class="lc-label">{{ section.settings.label | default: 'Who We Are' }}</span>
        <h2 class="lc-heading">{{ section.settings.heading | default: "Saudi Arabia's Trusted Laboratory Supplier" }}</h2>
        <p class="lc-subtext" style="margin-top:18px; max-width:520px;">
          {{ section.settings.body | default: 'LABCON specializes in supplying laboratory support products in Saudi Arabia, with a focus on reliable sourcing, practical product selection, and responsive support for governmental, private, industrial, academic, and research laboratories.' }}
        </p>
        {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '/pages/labcon-at-a-glance' }}" class="lc-btn lc-btn--outline-dark" style="margin-top:28px;">
          {{ section.settings.cta_label }}
        </a>
        {%- endif -%}
      </div>

      <!-- Right: 3 stat pillars -->
      <div class="labcon-intro__pillars">
        {%- assign pillars = section.blocks | where: "type", "pillar" -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'pillar' -%}
          <div class="labcon-pillar" {{ block.shopify_attributes }}>
            <div class="labcon-pillar__icon">
              {%- if block.settings.icon == 'sourcing' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {%- elsif block.settings.icon == 'catalog' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 10h16M4 14h10"/></svg>
              {%- elsif block.settings.icon == 'support' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18.364 5.636A9 9 0 1 1 5.636 18.364 9 9 0 0 1 18.364 5.636z"/><path d="M12 8v4l3 3"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              {%- endif -%}
            </div>
            <div class="labcon-pillar__body">
              <strong>{{ block.settings.title }}</strong>
              <span>{{ block.settings.text }}</span>
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<style>
.labcon-intro {
  background: #ffffff;
  border-top: 1px solid #f0f0f0;
}

.labcon-intro__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.labcon-intro__pillars {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.labcon-pillar {
  display: flex;
  align-items: flex-start;
  gap: 18px;
  padding: 24px 0;
  border-bottom: 1px solid #f0f0f0;
}
.labcon-pillar:first-child { border-top: 1px solid #f0f0f0; }

.labcon-pillar__icon {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  background: rgba(229,61,28,0.08);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e53d1c;
}
.labcon-pillar__icon svg {
  width: 20px;
  height: 20px;
}

.labcon-pillar__body {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.labcon-pillar__body strong {
  font-size: 15px;
  font-weight: 600;
  color: #0e0e0d;
  line-height: 1.3;
}
.labcon-pillar__body span {
  font-size: 14px;
  color: #6f7070;
  line-height: 1.5;
}

@media (max-width: 992px) {
  .labcon-intro__grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}
</style>

{% schema %}
{
  "name": "LABCON Intro",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Who We Are"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Saudi Arabia's Trusted Laboratory Supplier"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "LABCON specializes in supplying laboratory support products in Saudi Arabia, with a focus on reliable sourcing, practical product selection, and responsive support for governmental, private, industrial, academic, and research laboratories."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "LABCON at a Glance"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "sourcing", "label": "Checkmark / Sourcing" },
            { "value": "catalog",  "label": "List / Catalog" },
            { "value": "support",  "label": "Clock / Support" },
            { "value": "info",     "label": "Info" }
          ],
          "default": "info"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Reliable Sourcing"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Short description",
          "default": "Products sourced from trusted, verified manufacturers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LABCON Intro",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "icon": "sourcing",
            "title": "Reliable Sourcing",
            "text": "Products sourced from verified, trusted manufacturers."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "catalog",
            "title": "B2B Product Catalog",
            "text": "Browse and request a quote — no retail checkout."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "support",
            "title": "Responsive Support",
            "text": "Technical and commercial support for inquiries and tenders."
          }
        }
      ]
    }
  ]
}
{% endschema %}
