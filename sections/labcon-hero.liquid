{%- assign hero_bg = section.settings.background_image -%}
{%- assign bg_url = hero_bg | img_url: 'master' | default: ('hero-bg.jpg' | asset_url) -%}

<section
  class="labcon-hero"
  style="background-image: url('{{ bg_url }}');"
  aria-label="Hero"
>
  <div class="labcon-hero__overlay"></div>
  <div class="container labcon-hero__inner">
    <div class="labcon-hero__content">
      <span class="lc-label" style="color:#e53d1c; margin-bottom:20px;">
        {{ section.settings.eyebrow | default: 'Laboratory Support Products' }}
      </span>
      <h1 class="labcon-hero__title">
        {{ section.settings.headline | default: 'Reliable Solutions for<br>Laboratory Support.' }}
      </h1>
      <p class="labcon-hero__sub">
        {{ section.settings.subtext | default: 'Laboratory products and support solutions for analytical, reference, microbiology, chromatography, consumables, sample preparation, and daily laboratory operations.' }}
      </p>
      <div class="labcon-hero__ctas">
        <a href="{{ section.settings.cta_primary_link | default: '/collections/all' }}" class="lc-btn lc-btn--red">
          {{ section.settings.cta_primary_label | default: 'Explore Product Catalog' }}
        </a>
        <a href="{{ section.settings.cta_secondary_link | default: '/pages/contact' }}" class="lc-btn lc-btn--outline-white">
          {{ section.settings.cta_secondary_label | default: 'Contact LABCON' }}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
.labcon-hero {
  position: relative;
  min-height: 88vh;
  display: flex;
  align-items: center;
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
}

.labcon-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    108deg,
    rgba(14,14,13,0.94) 0%,
    rgba(14,14,13,0.88) 55%,
    rgba(14,14,13,0.65) 100%
  );
  z-index: 1;
}

.labcon-hero__inner {
  position: relative;
  z-index: 2;
  padding-top: 100px;
  padding-bottom: 80px;
}

.labcon-hero__content {
  max-width: 680px;
}

.labcon-hero__title {
  font-size: clamp(2rem, 5vw, 3.4rem);
  font-weight: 700;
  line-height: 1.15;
  color: #ffffff;
  letter-spacing: -0.025em;
  margin-bottom: 22px;
  margin-top: 0;
}

.labcon-hero__sub {
  font-size: 1.05rem;
  line-height: 1.75;
  color: rgba(255,255,255,0.68);
  max-width: 560px;
  margin-bottom: 40px;
}

.labcon-hero__ctas {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  align-items: center;
}

/* Accent red bar beneath hero */
.labcon-hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 120px;
  height: 4px;
  background: #e53d1c;
  z-index: 3;
}

@media (max-width: 768px) {
  .labcon-hero { min-height: 100vh; }
  .labcon-hero__inner { padding-top: 120px; }
  .labcon-hero__title { font-size: 2rem; }
  .labcon-hero__sub { font-size: 0.95rem; }
}
</style>

{% schema %}
{
  "name": "LABCON Hero",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Laboratory Support Products"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Reliable Solutions for<br>Laboratory Support."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Supporting text",
      "default": "Laboratory products and support solutions for analytical, reference, microbiology, chromatography, consumables, sample preparation, and daily laboratory operations."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Explore Product Catalog"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Contact LABCON"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [
    {
      "name": "LABCON Hero"
    }
  ]
}
{% endschema %}
