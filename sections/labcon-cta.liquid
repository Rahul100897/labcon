<section class="labcon-cta" style="background: #e53d1c;">
  <div class="container labcon-cta__inner">
    <div class="labcon-cta__text">
      <h2 class="labcon-cta__heading">
        {{ section.settings.heading | default: 'Looking for a specific laboratory product?' }}
      </h2>
      <p class="labcon-cta__sub">
        {{ section.settings.subtext | default: 'Submit a quote request — our team will respond with availability, pricing, and lead time.' }}
      </p>
    </div>
    <div class="labcon-cta__actions">
      <a href="{{ section.settings.cta_primary_link | default: '/collections/all' }}" class="lc-btn" style="background:#ffffff; color:#e53d1c; border-color:#ffffff;">
        {{ section.settings.cta_primary_label | default: 'Browse Product Catalog' }}
      </a>
      <a href="{{ section.settings.cta_secondary_link | default: '/pages/contact' }}" class="lc-btn lc-btn--outline-white">
        {{ section.settings.cta_secondary_label | default: 'Contact Us' }}
      </a>
    </div>
  </div>
</section>

<style>
.labcon-cta {
  padding: 72px 0;
}

.labcon-cta__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
}

.labcon-cta__text { max-width: 560px; }

.labcon-cta__heading {
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 10px;
  line-height: 1.2;
}

.labcon-cta__sub {
  font-size: 0.92rem;
  color: rgba(255,255,255,0.8);
  margin: 0;
  line-height: 1.6;
}

.labcon-cta__actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .labcon-cta__inner { flex-direction: column; align-items: flex-start; }
  .labcon-cta__text { max-width: 100%; }
}
</style>

{% schema %}
{
  "name": "LABCON CTA Banner",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Looking for a specific laboratory product?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Submit a quote request — our team will respond with availability, pricing, and lead time."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Browse Product Catalog"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [{ "name": "LABCON CTA Banner" }]
}
{% endschema %}
