<!-- labcon-glance.liquid -->

<!-- ── Page Header ──────────────────────────────────── -->
<section class="lc-page-header lc-page-header--dark">
  <div class="container">
    <span class="lc-label">Company Profile</span>
    <h1 class="lc-page-header__title">LABCON at a Glance</h1>
    <p class="lc-page-header__sub">A Saudi-based laboratory support specialist — reliable sourcing, practical product selection, and responsive service.</p>
  </div>
</section>

<!-- ── Who We Are ───────────────────────────────────── -->
<section class="lc-glance-who lc-section">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <span class="lc-label">Who We Are</span>
        <h2 class="lc-heading" style="margin-top:14px;">A Trusted Partner for Laboratory Support in Saudi Arabia</h2>
        <p class="lc-subtext">LABCON is a Saudi-based company specialized in supplying laboratory support products and solutions for laboratories across governmental, private, academic, research, industrial, and quality control sectors.</p>
        <p class="lc-subtext" style="margin-top:12px;">We focus on reliable sourcing, practical product selection, and responsive communication — ensuring that laboratories have access to the right products when they need them.</p>
        <a href="/pages/contact" class="lc-btn lc-btn--outline-dark" style="margin-top:28px;">Contact LABCON</a>
      </div>
      <div class="col-lg-6">
        <div class="lc-glance-who__stats">
          <div class="lc-glance-stat">
            <span class="lc-glance-stat__num">12</span>
            <span class="lc-glance-stat__label">Product Categories</span>
          </div>
          <div class="lc-glance-stat">
            <span class="lc-glance-stat__num">2</span>
            <span class="lc-glance-stat__label">Product Families</span>
          </div>
          <div class="lc-glance-stat">
            <span class="lc-glance-stat__num">B2B</span>
            <span class="lc-glance-stat__label">Focused Catalog</span>
          </div>
          <div class="lc-glance-stat">
            <span class="lc-glance-stat__num">KSA</span>
            <span class="lc-glance-stat__label">Saudi Arabia</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── What We Provide ──────────────────────────────── -->
<section class="lc-glance-provide lc-section" style="background:var(--lc-off-white);">
  <div class="container">
    <div class="text-center mb-5">
      <span class="lc-label" style="justify-content:center;">What We Provide</span>
      <h2 class="lc-heading" style="margin-top:14px;">Our Product Portfolio</h2>
      <p class="lc-subtext mx-auto" style="max-width:560px;">Organized into two main product families covering 12 technical categories for complete laboratory support.</p>
    </div>

    <!-- Family 1 -->
    <div class="lc-glance-family">
      <div class="lc-glance-family__header">
        <span class="lc-glance-family__num">01</span>
        <h3 class="lc-glance-family__title">Analytical & Reference Products</h3>
      </div>
      <div class="row g-3">
        {%- assign analytical = "Referenceware|Reference Materials & Standards,Analyticalware|Chromatography Consumables,Bioware|Biological Products,Solvents & Reagents|High-Purity Solvents & Reagents" | split: "," -%}
        {%- for item in analytical -%}
          {%- assign parts = item | split: "|" -%}
          <div class="col-sm-6 col-md-3">
            <a href="/collections/{{ parts[0] | handleize }}" class="lc-glance-cat-card">
              <span class="lc-glance-cat-card__name">{{ parts[0] }}</span>
              <span class="lc-glance-cat-card__desc">{{ parts[1] }}</span>
              <span class="lc-glance-cat-card__arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Family 2 -->
    <div class="lc-glance-family" style="margin-top:40px;">
      <div class="lc-glance-family__header">
        <span class="lc-glance-family__num">02</span>
        <h3 class="lc-glance-family__title">Laboratory Consumables</h3>
      </div>
      <div class="row g-3">
        {%- assign consumables = "Filterware|Filtration Products,Plasticware|Plastic Laboratory Tools,Glassware|Lab Glass Tools,Volumetricware|Volumetric Measuring Tools,Sampleware|Sample Collection Products,Cultureware|Microbiology Culture,Safetyware|Lab Safety Supplies,Generalware|General Consumables" | split: "," -%}
        {%- for item in consumables -%}
          {%- assign parts = item | split: "|" -%}
          <div class="col-sm-6 col-md-3">
            <a href="/collections/{{ parts[0] | handleize }}" class="lc-glance-cat-card">
              <span class="lc-glance-cat-card__name">{{ parts[0] }}</span>
              <span class="lc-glance-cat-card__desc">{{ parts[1] }}</span>
              <span class="lc-glance-cat-card__arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="text-center" style="margin-top:40px;">
      <a href="/collections/all" class="lc-btn lc-btn--red">Browse Full Product Catalog</a>
    </div>
  </div>
</section>

<!-- ── Our Focus ─────────────────────────────────────── -->
<section class="lc-glance-focus lc-section">
  <div class="container">
    <div class="text-center mb-5">
      <span class="lc-label" style="justify-content:center;">Our Focus</span>
      <h2 class="lc-heading" style="margin-top:14px;">What Sets Us Apart</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-3">
        <div class="lc-glance-focus-card">
          <div class="lc-glance-focus-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="lc-glance-focus-card__title">Reliable Sourcing</h3>
          <p class="lc-glance-focus-card__text">Products sourced from reputable manufacturers with consistent quality and availability for laboratory operations.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="lc-glance-focus-card">
          <div class="lc-glance-focus-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 class="lc-glance-focus-card__title">Practical Selection</h3>
          <p class="lc-glance-focus-card__text">Curated product portfolio focused on what laboratories actually need — covering analytical, reference, and consumable requirements.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="lc-glance-focus-card">
          <div class="lc-glance-focus-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3 class="lc-glance-focus-card__title">Responsive Support</h3>
          <p class="lc-glance-focus-card__text">Direct communication and responsive service for product inquiries, technical questions, and quote requests.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3">
        <div class="lc-glance-focus-card">
          <div class="lc-glance-focus-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          </div>
          <h3 class="lc-glance-focus-card__title">Simplified Access</h3>
          <p class="lc-glance-focus-card__text">A clean B2B catalog with a straightforward quote process — browse, add to Quote List, and submit your request in minutes.</p>
        </div>
      </div>
    </div>
  </div>
</section>

