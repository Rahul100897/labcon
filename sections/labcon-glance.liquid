<!-- ── CTA ───────────────────────────────────────────── -->
<section class="lc-glance-cta lc-section-sm" style="background:var(--lc-grey-light);">
  <div class="container text-center">
    <h2 class="lc-heading" style="margin-bottom:14px;">Looking for a Specific Laboratory Product?</h2>
    <p class="lc-subtext mx-auto" style="max-width:480px;">Explore the full product catalog or contact the LABCON team directly for assistance.</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap" style="margin-top:28px;">
      <a href="/collections/all" class="lc-btn lc-btn--red">Explore Product Catalog</a>
      <a href="/pages/contact" class="lc-btn lc-btn--outline-dark">Contact LABCON</a>
    </div>
  </div>
</section>

<style>
/* ── Stats ───────────────────────────────────── */
.lc-glance-who__stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  background: #e8e8e8;
  border-radius: 4px;
  overflow: hidden;
}
.lc-glance-stat {
  background: #fff;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.lc-glance-stat__num {
  font-size: 36px;
  font-weight: 800;
  color: var(--lc-red);
  line-height: 1;
  letter-spacing: -0.02em;
}
.lc-glance-stat__label {
  font-size: 12px;
  font-weight: 600;
  color: var(--lc-grey-mid);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* ── Product Families ────────────────────────── */
.lc-glance-family__header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}
.lc-glance-family__num {
  font-size: 20px;
  font-weight: 800;
  color: var(--lc-red);
  letter-spacing: 0.06em;
}
.lc-glance-family__title {
  font-size: 20px;
  font-weight: 700;
  color: var(--lc-dark);
  margin: 0;
}
.lc-glance-cat-card {
  display: flex;
  flex-direction: column;
  gap: 4px;
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 3px;
  padding: 20px;
  text-decoration: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  position: relative;
  height: 100%;
}
.lc-glance-cat-card:hover {
  border-color: var(--lc-red);
  box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  text-decoration: none;
}
.lc-glance-cat-card__name {
  font-size: 18px;
  font-weight: 700;
  color: var(--lc-dark);
  display: block;
}
.lc-glance-cat-card__desc {
  font-size: 16px;
  color: var(--lc-grey-mid);
  display: block;
  line-height: 1.5;
}
.lc-glance-cat-card__arrow {
  display: block;
  color: var(--lc-red);
  margin-top: 10px;
  opacity: 0;
  transition: opacity 0.2s;
}
.lc-glance-cat-card:hover .lc-glance-cat-card__arrow { opacity: 1; }

/* ── Focus Cards ─────────────────────────────── */
.lc-glance-focus-card {
  padding: 32px 28px;
  border: 1px solid #e8e8e8;
  border-radius: 3px;
  height: 100%;
  transition: border-color 0.2s;
}
.lc-glance-focus-card:hover { border-color: var(--lc-red); }
.lc-glance-focus-card__icon {
  width: 52px;
  height: 52px;
  background: rgba(229,61,28,0.08);
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--lc-red);
  margin-bottom: 20px;
}
.lc-glance-focus-card__title {
  font-size: 16px;
  font-weight: 700;
  color: var(--lc-dark);
  margin-bottom: 10px;
}
.lc-glance-focus-card__text {
  font-size: 14px;
  color: var(--lc-grey-mid);
  line-height: 1.7;
  margin: 0;
}

/* ── Why List ────────────────────────────────── */
.lc-glance-why__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.lc-glance-why__item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  font-size: 15px;
  color: rgba(255,255,255,0.75);
  line-height: 1.6;
}
.lc-glance-why__check {
  flex-shrink: 0;
  width: 26px;
  height: 26px;
  background: rgba(229,61,28,0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--lc-red);
  margin-top: 1px;
}
</style>

{% schema %}
{
  "name": "LABCON at a Glance",
  "settings": [],
  "presets": [{ "name": "LABCON at a Glance" }]
}
{% endschema %}
