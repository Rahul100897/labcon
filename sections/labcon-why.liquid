<section class="labcon-why lc-section" style="background: #f7f8f7; border-top: 1px solid #ebebeb;">
  <div class="container">
    <div class="labcon-why__grid">

      <!-- Left: heading -->
      <div class="labcon-why__left">
        <span class="lc-label">{{ section.settings.label | default: 'Why LABCON' }}</span>
        <h2 class="lc-heading" style="max-width: 300px;">{{ section.settings.heading | default: 'Built for Laboratories. Not Retail.' }}</h2>
        {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '/pages/labcon-at-a-glance' }}" class="lc-btn lc-btn--red" style="margin-top:28px;">
          {{ section.settings.cta_label }}
        </a>
        {%- endif -%}
      </div>

      <!-- Right: reasons list -->
      <div class="labcon-why__right">
        {%- for block in section.blocks -%}
          {%- if block.type == 'reason' -%}
          <div class="labcon-why-item" {{ block.shopify_attributes }}>
            <div class="labcon-why-item__check">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l3 3 7-7"/></svg>
            </div>
            <div class="labcon-why-item__body">
              <strong>{{ block.settings.title }}</strong>
              {%- if block.settings.text != blank -%}
              <span>{{ block.settings.text }}</span>
              {%- endif -%}
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<style>
.labcon-why__grid {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 64px;
  align-items: start;
}

.labcon-why__left {
  position: sticky;
  top: 120px;
}

.labcon-why__right {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.labcon-why-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 20px 0;
  border-bottom: 1px solid #ebebeb;
}
.labcon-why-item:first-child { border-top: 1px solid #ebebeb; }

.labcon-why-item__check {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  background: rgba(229,61,28,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e53d1c;
  margin-top: 2px;
}
.labcon-why-item__check svg {
  width: 14px;
  height: 14px;
}

.labcon-why-item__body {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.labcon-why-item__body strong {
  font-size: 16px;
  font-weight: 700;
  color: #0e0e0d;
  line-height: 1.3;
}
.labcon-why-item__body span {
  font-size: 14px;
  color: #6f7070;
  line-height: 1.55;
}

@media (max-width: 992px) {
  .labcon-why__grid {
    grid-template-columns: 1fr;
    gap: 36px;
  }
  .labcon-why__left { position: static; }
}
</style>

{% schema %}
{
  "name": "LABCON Why",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Why LABCON"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Laboratories. Not Retail."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Learn More About Us"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Reliable sourcing"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Short description",
          "default": "Products sourced from verified, trusted manufacturers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LABCON Why",
      "blocks": [
        {
          "type": "reason",
          "settings": {
            "title": "Reliable product sourcing",
            "text": "We source from verified, internationally trusted manufacturers with consistent quality records."
          }
        },
        {
          "type": "reason",
          "settings": {
            "title": "B2B quote process — no retail checkout",
            "text": "Our catalog is designed for institutional procurement. Browse freely, build a quote list, and submit."
          }
        },
        {
          "type": "reason",
          "settings": {
            "title": "Tender and procurement support",
            "text": "We assist with tender documentation, technical specifications, and commercial coordination."
          }
        },
        {
          "type": "reason",
          "settings": {
            "title": "Technical and commercial expertise",
            "text": "Our team provides application guidance and product selection support across all categories."
          }
        },
        {
          "type": "reason",
          "settings": {
            "title": "Simplified access to laboratory products",
            "text": "One trusted supplier for 12 product categories covering the full range of lab support needs."
          }
        }
      ]
    }
  ]
}
{% endschema %}
